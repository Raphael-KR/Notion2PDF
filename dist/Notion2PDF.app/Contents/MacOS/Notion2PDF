#!/bin/zsh
set -uo pipefail

export PATH="/opt/homebrew/bin:/Users/raphael/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export HOME="${HOME:-/Users/raphael}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

APP_EXECUTABLE="$0"
APP_CONTENTS="$(cd "$(dirname "$APP_EXECUTABLE")/.." && pwd)"
PROJECT_ROOT="$(cd "$APP_CONTENTS/../../.." && pwd)"
PYTHON_BIN="$PROJECT_ROOT/.venv/bin/python"
RUN_ID="$(/bin/date +%Y%m%d-%H%M%S)"
LOG_FILE="$PROJECT_ROOT/tmp/macos-app-$RUN_ID.log"
LATEST_LOG="$PROJECT_ROOT/tmp/macos-app.latest.log"

mkdir -p "$PROJECT_ROOT/tmp"

copy_latest_log() {
  /bin/cp "$LOG_FILE" "$LATEST_LOG" 2>/dev/null || true
}

log_line() {
  echo "$1" >>"$LOG_FILE"
  copy_latest_log
}

result_message() {
  local status="$1"
  local pdf_path="${output_pdf:-미지정}"
  local html_path="${html_output:-저장 안 함}"
  cat <<EOF
$status

PDF 저장 위치:
$pdf_path

HTML 저장 위치:
$html_path

로그:
$LOG_FILE
EOF
}

show_error() {
  local message="$1"
  /usr/bin/osascript - "$message" <<'APPLESCRIPT' >/dev/null 2>&1
on run argv
  display dialog (item 1 of argv) buttons {"OK"} default button "OK" with icon stop
end run
APPLESCRIPT
}

notify_user() {
  local title="$1"
  local message="$2"
  /usr/bin/osascript - "$title" "$message" <<'APPLESCRIPT' >/dev/null 2>&1
on run argv
  display notification (item 2 of argv) with title (item 1 of argv)
end run
APPLESCRIPT
}

show_failure_result() {
  local message="$1"
  /usr/bin/osascript - "$message" "$LOG_FILE" "$output_pdf" <<'APPLESCRIPT'
on run argv
set messageText to item 1 of argv
set logPath to item 2 of argv
set outputPath to item 3 of argv
display dialog messageText buttons {"닫기", "저장 폴더 보기", "로그 열기"} default button "로그 열기" with icon stop
set chosenButton to button returned of result
if chosenButton is "로그 열기" then
  do shell script "/usr/bin/open " & quoted form of logPath
else if chosenButton is "저장 폴더 보기" and outputPath is not "" then
  do shell script "/usr/bin/open -R " & quoted form of outputPath
end if
APPLESCRIPT
}

show_success_result() {
  local message="$1"
  if [[ -n "$html_output" ]]; then
    /usr/bin/osascript - "$output_pdf" "$html_output" "$message" <<'APPLESCRIPT'
on run argv
set outputPath to item 1 of argv
set htmlPath to item 2 of argv
set messageText to item 3 of argv
display dialog messageText buttons {"HTML 열기", "Finder에서 보기", "PDF 열기"} default button "PDF 열기" with icon note
set chosenButton to button returned of result
if chosenButton is "PDF 열기" then
  do shell script "/usr/bin/open " & quoted form of outputPath
else if chosenButton is "Finder에서 보기" then
  do shell script "/usr/bin/open -R " & quoted form of outputPath
else if chosenButton is "HTML 열기" then
  do shell script "/usr/bin/open " & quoted form of htmlPath
end if
APPLESCRIPT
  else
    /usr/bin/osascript - "$output_pdf" "$message" <<'APPLESCRIPT'
on run argv
set outputPath to item 1 of argv
set messageText to item 2 of argv
display dialog messageText buttons {"닫기", "Finder에서 보기", "PDF 열기"} default button "PDF 열기" with icon note
set chosenButton to button returned of result
if chosenButton is "PDF 열기" then
  do shell script "/usr/bin/open " & quoted form of outputPath
else if chosenButton is "Finder에서 보기" then
  do shell script "/usr/bin/open -R " & quoted form of outputPath
end if
APPLESCRIPT
  fi
}

{
  echo "Started: $(/bin/date)"
  echo "Project: $PROJECT_ROOT"
  echo "HOME: $HOME"
  echo "PATH: $PATH"
  echo "Python: $PYTHON_BIN"
} >"$LOG_FILE"
copy_latest_log

if [[ ! -x "$PYTHON_BIN" ]]; then
  log_line "ERROR: missing project venv: $PYTHON_BIN"
  show_failure_result "$(result_message "실패: 프로젝트 venv를 찾을 수 없습니다.")"
  exit 1
fi

if ! command -v ntn >/dev/null 2>&1; then
  log_line "ERROR: ntn not found on PATH"
  show_failure_result "$(result_message "실패: Notion CLI(ntn)를 찾을 수 없습니다.")"
  exit 1
fi

NTN_BIN="$(command -v ntn)"
log_line "ntn: $NTN_BIN"

if [[ "${1:-}" == "--self-test" ]]; then
  {
    "$PYTHON_BIN" --version
    "$NTN_BIN" --version
    plutil -lint "$APP_CONTENTS/Info.plist"
    "$NTN_BIN" api v1/users/me >/dev/null
    echo "Self-test OK"
  } >>"$LOG_FILE" 2>&1
  exit_status="$?"
  copy_latest_log
  cat "$LOG_FILE"
  exit "$exit_status"
fi

notion_url=""
output_pdf=""
html_output=""
save_html="0"
interactive="1"

if [[ "$#" -ge 2 ]]; then
  notion_url="$1"
  output_pdf="$2"
  if [[ "$#" -ge 3 ]]; then
    html_output="$3"
  fi
  interactive="0"
fi

if [[ "$interactive" == "1" ]]; then
  notion_url="$(/usr/bin/osascript <<'APPLESCRIPT' 2>>"$LOG_FILE"
tell application "System Events"
  activate
end tell

set dialogResult to display dialog "PDF로 변환할 Notion 링크를 붙여넣으세요." default answer "" buttons {"취소", "다음"} default button "다음" cancel button "취소" with title "Notion 링크" with icon note
return text returned of dialogResult
APPLESCRIPT
)"
  input_status="$?"
  copy_latest_log
  if [[ "$input_status" -ne 0 ]]; then
    log_line "Input dialog cancelled or failed with status $input_status"
    exit 0
  fi

  if [[ -z "$notion_url" ]]; then
    exit 0
  fi

  save_html_choice="$(/usr/bin/osascript <<'APPLESCRIPT' 2>>"$LOG_FILE"
tell application "System Events"
  activate
end tell

set dialogResult to display dialog "중간 HTML도 함께 저장할까요?" buttons {"저장 안 함", "HTML 저장"} default button "저장 안 함" cancel button "저장 안 함" with title "중간 HTML 저장" with icon note
return button returned of dialogResult
APPLESCRIPT
)"
  html_choice_status="$?"
  copy_latest_log
  if [[ "$html_choice_status" -ne 0 ]]; then
    save_html="0"
  elif [[ "$save_html_choice" == "HTML 저장" ]]; then
    save_html="1"
  else
    save_html="0"
  fi

  log_line "Fetching page title..."
  page_title="$("$PYTHON_BIN" "$PROJECT_ROOT/notion_to_pdf.py" "$notion_url" --title-only --ntn-path "$NTN_BIN" 2>>"$LOG_FILE")"
  title_status="$?"
  copy_latest_log
  if [[ "$title_status" -ne 0 ]]; then
    show_failure_result "$(result_message "실패: Notion 페이지 제목을 가져오지 못했습니다.")"
    exit "$title_status"
  fi
  if [[ -z "$page_title" ]]; then
    page_title="notion-page"
  fi

  default_pdf_name="$(TITLE="$page_title" "$PYTHON_BIN" -c 'import os, re
title = os.environ.get("TITLE", "notion-page")
title = re.sub(r"[/:\\\\?%*|\"<>\\n\\r]+", "-", title).strip(" .-") or "notion-page"
print(title[:120] + ".pdf")')"

  output_pdf="$(/usr/bin/osascript - "$default_pdf_name" <<'APPLESCRIPT'
on run argv
set defaultName to item 1 of argv
set chosenFile to choose file name with prompt "PDF 저장 위치를 선택하세요." default name defaultName
return POSIX path of chosenFile
end run
APPLESCRIPT
)"
  output_status="$?"
  copy_latest_log
  if [[ "$output_status" -ne 0 ]]; then
    log_line "Save dialog cancelled or failed with status $output_status"
    exit 0
  fi
fi

if [[ -z "$notion_url" || -z "$output_pdf" ]]; then
  log_line "ERROR: missing notion URL or output PDF"
  show_failure_result "$(result_message "실패: Notion 링크와 PDF 출력 경로가 필요합니다.")"
  exit 1
fi

if [[ "$interactive" == "1" && "$save_html" == "1" && -z "$html_output" ]]; then
  output_dir="$(dirname "$output_pdf")"
  output_name="$(basename "$output_pdf")"
  html_output="$output_dir/${output_name:r}.html"
fi

command_args=("$PROJECT_ROOT/notion_to_pdf.py" "$notion_url" "$output_pdf" "--ntn-path" "$NTN_BIN")
if [[ -n "$html_output" ]]; then
  command_args+=("--html-output" "$html_output")
fi

if [[ "$interactive" == "1" ]]; then
  notify_user "Notion2PDF" "PDF 변환을 시작했습니다."
fi

{
  echo "Output: $output_pdf"
  echo "Save HTML: $save_html"
  echo "HTML: ${html_output:-disabled}"
  "$NTN_BIN" --version
  echo "Checking ntn auth..."
  "$NTN_BIN" api v1/users/me >/dev/null
  echo "Converting..."
  "$PYTHON_BIN" "${command_args[@]}"
} >>"$LOG_FILE" 2>&1
exit_status="$?"
copy_latest_log

if [[ "$exit_status" -ne 0 ]]; then
  if [[ "$interactive" == "1" ]]; then
    show_failure_result "$(result_message "실패: PDF 변환에 실패했습니다.")"
  else
    cat "$LOG_FILE" >&2
  fi
  exit "$exit_status"
fi

if [[ "$interactive" == "1" ]]; then
  success_message="$(result_message "성공: PDF 변환이 완료되었습니다.")"
  show_success_result "$success_message"
else
  cat "$LOG_FILE"
fi
